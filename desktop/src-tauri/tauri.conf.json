{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Harvest",
  "version": "0.1.0",
  "identifier": "com.harvest.desktop",
  "build": {
    "beforeDevCommand": "pnpm dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "pnpm build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "Harvest",
        "width": 900,
        "height": 650
      },
      {
        "label": "display",
        "title": "Harvest — Display",
        "width": 1024,
        "height": 576,
        "visible": false,
        "decorations": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "externalBin": ["binaries/backend"]
  }
}
