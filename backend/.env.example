APP_NAME=Harvest
APP_VERSION=1.0.0
DEBUG=true

# Local/desktop dev: local SQLite file, no server needed.
# Hosted mode: postgresql://user:password@host:5432/harvest
DATABASE_URL=sqlite:///./harvest.db
DB_POOL_SIZE=5
DB_MAX_OVERFLOW=10

# Hosted mode only (Phase 11) — not used by the desktop build.
REDIS_URL=redis://localhost:6379/0

# Generate a real random value for any non-local use, e.g.: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=8c2559670bec891adc654af007714c91f9f78be8ed20d1a41254034b27088a2c
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30

# Tauri's dev server runs on 1420 (desktop/src-tauri/tauri.conf.json), not React's default 3000.
ALLOWED_ORIGINS=["http://localhost:1420"]

# STT (Phase 04). "tiny" is the default because it's what actually keeps up
# live on a modest CPU (see app-phases/04-speech-to-text-pipeline.md for
# measured numbers) -- bump to "base" or "small" on faster hardware for
# better accuracy, or set WHISPER_DEVICE=cuda/WHISPER_COMPUTE_TYPE=float16
# if a GPU is available.
WHISPER_MODEL_SIZE=tiny
WHISPER_DEVICE=cpu
WHISPER_COMPUTE_TYPE=int8
WHISPER_LANGUAGE=en
# 0 = auto (ctranslate2 decides). If trying WHISPER_MODEL_SIZE=base, capping
# this at roughly half your CPU's core count measurably cut latency and
# variance in testing -- but the ideal value is machine-specific, tune it on
# the real target hardware, not from a number copied elsewhere.
WHISPER_CPU_THREADS=0

# Speech-boundary-aware chunking, not a fixed clock: buffer at least MIN
# seconds, transcribe as soon as a real pause (SILENCE_MS) is detected, or
# once MAX seconds is hit regardless (bounds latency for a run-on sentence).
TRANSCRIPT_MIN_CHUNK_SECONDS=1.0
TRANSCRIPT_MAX_CHUNK_SECONDS=8.0
TRANSCRIPT_SILENCE_MS=500
